<!DOCTYPE html>
<html lang="fr">
  <%- include('./layout/head') %>
  <body>
    <%- include('./layout/header') %>

    <div class="container" role="article" aria-label="Commande acceptée">
      <p class="muted">Bonjour <%= user.fullname %>,</p>

      <p>
        Bonne nouvelle 🎉  
        Votre commande <strong>#<%= order._id %></strong> a été
        <strong>acceptée</strong> et est actuellement en préparation.
      </p>

      <ul>
        <% order.products.forEach((n) => { %>
          <li><%= n.productId.label %> - <%= n.price %> x <%= n.quantity %></li>
        <% }) %>
      </ul>

      <p><strong>Montant total :</strong> <%= order.totalPrice %></p>

      <p>
        Vous serez informé(e) dès que votre commande sera prête pour le retrait.
        Merci pour votre confiance.
      </p>

      <p style="margin-top: 16px">
        <a
          class="button btn-primary"
          href="<%= url_profil %>"
          target="_blank"
          rel="noopener"
        >
          Suivre ma commande
        </a>
      </p>

      <%- include('./layout/footer') %>
    </div>
  </body>
</html>
